        {
          "id": 76,
          "title": "수집/정규화/DB 재연결·실패 원시 카운터",
          "description": "누적 카운터라서 값 자체보다 '늘어나는지'가 중요하다. mqtt_reconnect/db_reconnect가 계속 늘면 해당 연결이 반복적으로 끊기고 있다는 뜻.",
          "type": "table",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "gridPos": { "h": 7, "w": 12, "x": 12, "y": 72 },
          "fieldConfig": {
            "defaults": { "custom": { "align": "center", "displayMode": "auto" } },
            "overrides": [
              { "matcher": { "id": "byName", "options": "Value" }, "properties": [{ "id": "displayName", "value": "누적 값" }] }
            ]
          },
          "transformations": [
            { "id": "merge", "options": {} }
          ],
          "targets": [
            {
              "datasource": { "type": "prometheus", "uid": "prometheus" },
              "expr": "label_replace(bridge_mqtt_reconnect_total or 0 * absent(bridge_mqtt_reconnect_total), \"지표\", \"MQTT 재접속 횟수\", \"job\", \".*\")\n  or label_replace(dbsink_reconnect_total or 0 * absent(dbsink_reconnect_total), \"지표\", \"DB 재연결 횟수\", \"job\", \".*\")\n  or label_replace(streams_uncaught_exceptions_total or 0 * absent(streams_uncaught_exceptions_total), \"지표\", \"정규화 스레드 예외 횟수\", \"job\", \".*\")\n  or label_replace(sum(bridge_kafka_send_total{result=\"failure\"}) or 0 * absent(bridge_kafka_send_total{result=\"failure\"}), \"지표\", \"Kafka 발행 실패 누적\", \"job\", \".*\")",
              "format": "table",
              "instant": true,
              "refId": "A"
            }
          ]
        },
