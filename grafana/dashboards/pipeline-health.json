        "overrides": []
      },
      "options": { "textMode": "value_and_name", "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "kafka_consumergroup_members{consumergroup=\"factory-linestate-streams\"}",
          "refId": "A"
        }
      ]
    },
    {
