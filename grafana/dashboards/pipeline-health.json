        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "label_replace(label_replace(label_replace(sum by (consumergroup) (kafka_consumergroup_lag{consumergroup=~\"factory-linestate-streams|factory-linestate-db-sink|factory-linestate-ws-backend\"}), \"stage\", \"② 데이터 합치기\", \"consumergroup\", \"factory-linestate-streams\"), \"stage\", \"③ DB 저장\", \"consumergroup\", \"factory-linestate-db-sink\"), \"stage\", \"④ 화면 전송\", \"consumergroup\", \"factory-linestate-ws-backend\")",
          "legendFormat": "{{stage}}",
