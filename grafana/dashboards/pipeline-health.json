          "type": "table",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "gridPos": { "h": 7, "w": 12, "x": 0, "y": 58 },
          "fieldConfig": {
            "defaults": { "custom": { "align": "center", "displayMode": "auto" } },
            "overrides": [
              { "matcher": { "id": "byName", "options": "Value" }, "properties": [{ "id": "displayName", "value": "누적 메시지 수" }] },
              { "matcher": { "id": "byName", "options": "topic" }, "properties": [
                { "id": "mappings", "value": [
                  { "type": "value", "options": {
                    "factory.modbus": { "text": "Modbus (온도/생산량)" },
                    "factory.roomenv": { "text": "MQTT (실내환경)" }
                  } }
                ] }
              ] }
            ]
          },
          "targets": [
            {
              "datasource": { "type": "prometheus", "uid": "prometheus" },
              "expr": "sum by (topic) (kafka_topic_partition_current_offset{topic=~\"factory.modbus|factory.roomenv\"})",
              "format": "table",
              "instant": true,
              "refId": "A"
            }
          ]
        },
        {
          "id": 12,
          "title": "② 데이터 합치기 단계 — 토픽/파티션별 상세 lag",
          "type": "table",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "gridPos": { "h": 7, "w": 12, "x": 12, "y": 58 },
          "fieldConfig": {
            "defaults": {
