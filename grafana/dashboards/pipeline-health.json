            { "type": "range", "options": { "from": 1, "to": 1000, "result": { "text": "켜져 있음" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
