{
  "title": "데이터 파이프라인 상태 (문제 위치 한눈에 보기)",
  "uid": "pipeline-health",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 100,
      "title": "① 공장 센서에서 데이터가 들어오고 있는지",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "panels": []
    },
    {
      "id": 1,
      "title": "온도 / 생산량 데이터 (Modbus)",
      "description": "공장 라인의 화력·몰드 온도, 생산개수 값이 계속 들어오고 있는지. '중단'이면 시뮬레이터 또는 수집 프로그램(KafkaBridge)이 멈춘 것.",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "noValue": "중단",
          "mappings": [
            { "type": "range", "options": { "from": 0, "to": 0.4, "result": { "text": "중단" } } },
            { "type": "range", "options": { "from": 0.4, "to": 1000000, "result": { "text": "정상 수집 중" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 0.4 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "textMode": "value_and_name", "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(kafka_topic_partition_current_offset{topic=\"factory.modbus\"}[1m]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "실내 온습도 데이터 (MQTT)",
      "description": "실내 온습도 값이 계속 들어오고 있는지. '중단'이면 MQTT 브로커 또는 수집 프로그램이 멈춘 것. (위 패널은 정상인데 이것만 중단이면 MQTT 쪽만 문제)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "noValue": "중단",
          "mappings": [
            { "type": "range", "options": { "from": 0, "to": 0.05, "result": { "text": "중단" } } },
            { "type": "range", "options": { "from": 0.05, "to": 1000000, "result": { "text": "정상 수집 중" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "textMode": "value_and_name", "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(kafka_topic_partition_current_offset{topic=\"factory.roomenv\"}[1m]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 200,
      "title": "② 온도 데이터 + 환경 데이터를 하나로 합치는 중간 처리",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 8 },
      "panels": []
    },
    {
      "id": 10,
      "title": "처리 프로그램이 켜져 있는지",
      "description": "'꺼짐'이면 이 단계를 담당하는 프로그램(LineStateStreams)이 다운된 것 — 재시작이 필요.",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 9 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
