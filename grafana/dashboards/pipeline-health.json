    {
      "id": 74,
      "title": "③ DB 연결 상태 / 재연결 발생 횟수",
      "description": "DB(TimescaleDB)가 죽었다 살아나도 프로그램은 죽지 않고 자동 재연결한다. '재연결 횟수'가 늘어난다는 건 그 사이에 DB가 한 번 이상 끊겼었다는 뜻(지금은 복구됐어도 기록은 남음).",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 50 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "noValue": "정보 없음",
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DB 연결 끊김 (재연결 시도 중)" } } },
            { "type": "range", "options": { "from": 1, "to": 1, "result": { "text": "DB 연결됨" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "textMode": "value_and_name", "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "dbsink_db_connected",
          "refId": "A"
        }
      ]
    },
    {
      "id": 600,
